<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/voting_background"
    android:padding="16dp">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <!-- Close button removed -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Poll"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar"
        android:text="Please cast your vote"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Instruction -->
    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title"
        android:layout_marginTop="24dp"
        android:text="1. Please cast your vote (single choice)"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp" />

    <!-- RadioGroup for candidates -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_section"
        android:layout_below="@id/tv_instruction"
        android:layout_marginTop="16dp">

        <RadioGroup
            android:id="@+id/radio_group_candidates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rb_candidate_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/voting_blue"
                android:padding="18dp"
                android:text="Candidate 1"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/voting_separator" />

            <RadioButton
                android:id="@+id/rb_candidate_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/voting_blue"
                android:padding="18dp"
                android:text="Candidate 2"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/voting_separator" />

            <RadioButton
                android:id="@+id/rb_candidate_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/voting_blue"
                android:padding="18dp"
                android:text="Candidate 3"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/voting_separator" />

            <RadioButton
                android:id="@+id/rb_candidate_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/voting_blue"
                android:padding="18dp"
                android:text="Candidate 4"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/voting_separator" />

            <RadioButton
                android:id="@+id/rb_candidate_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/voting_blue"
                android:padding="18dp"
                android:text="Candidate 5"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/voting_separator" />

        </RadioGroup>
    </ScrollView>

    <!-- Bottom Section containing Submit button and helper text -->
    <RelativeLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingTop="16dp">

        <!-- Row with Submit button -->
        <RelativeLayout
            android:id="@+id/action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:paddingRight="26dp">

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/voting_blue"
                android:text="Submit"
                android:textColor="@android:color/white"
                android:textSize="16sp" />
        </RelativeLayout>

    </RelativeLayout>

</RelativeLayout>